// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: Open Default Keymap`
// from the command palette.
[
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "u": "vim::Left",
      "p": "vim::Up",
      "e": "vim::Right",
      "i": "vim::Down",

      "k": "vim::Paste",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "U": "vim::FirstNonWhitespace",
      "E": "vim::EndOfLine",
      "h": "vim::Undo",
      "H": "vim::Redo",
      "l": "vim::InsertBefore",
      "L": "vim::InsertFirstNonWhitespace",

      "I": "editor::ShowSignatureHelp",

      "space space": "file_finder::Toggle",
      "space b d": "pane::CloseActiveItem",

      "é m": "vim::NextMethodStart",
      "é n": "window::ShowNextWindowTab",
      "ç n": "window::ShowPreviousWindowTab",
      "é é": "vim::GoToNextReference",
      "ç ç": "vim::GoToPreviousReference",
      "é d": "editor::GoToDiagnostic",
      "ç d": "editor::GoToPreviousDiagnostic",
      "é space": "vim::InsertEmptyLineBelow",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {},
  },
]
